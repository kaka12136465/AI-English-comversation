{
  "firestore": {
    "database": "(default)",
    "location": "asia-northeast1",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "venv",
        ".venv",
        "__pycache__",
        "*.pyc",
        ".env"
      ]
    }
  ],
  "hosting": {
    "public": "static",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/chat",
        "run": { "serviceId": "chat", "region": "asia-northeast1" }
      },
      {
        "source": "/generate",
        "run": { "serviceId": "generate", "region": "asia-northeast1" }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
